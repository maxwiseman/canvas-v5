{
	"name": "extension",
	"version": "0.0.0",
	"private": true,
	"description": "manifest.json description",
	"type": "module",
	"scripts": {
		"dev": "wxt --port 5555",
		"dev:firefox": "wxt -b firefox",
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox",
		"compile": "tsc --noEmit",
		"postinstall": "wxt prepare"
	},
	"dependencies": {
		"@canvas-v5/app": "workspace:*",
		"@canvas-v5/canvas-sdk": "workspace:*",
		"@tanstack/react-router": "^1.168.22",
		"lucide-react": "^1.8.0",
		"react": "catalog:",
		"react-dom": "catalog:"
	},
	"devDependencies": {
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@wxt-dev/module-react": "^1.1.5",
		"typescript": "^5.9.3",
		"wxt": "^0.20.26"
	}
}
